---
type Props = {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  /** ビジュアル画像URL（任意） */
  image?: string;
  imageAlt?: string;
};

const {
  eyebrow = 'Yokohama Sakae Public Wind Ensemble',
  title,
  subtitle,
  image = 'https://images.unsplash.com/photo-1465847899084-d164df4dedc6?auto=format&fit=crop&w=1400&q=80',
  imageAlt = '吹奏楽団の演奏風景',
} = Astro.props;
---

<section class="hero">
  <!-- 背景：ブラブだけ overflow:hidden の中に閉じ込める -->
  <div class="hero__bg" aria-hidden="true">
    <span class="hero__blob hero__blob--blue"></span>
    <span class="hero__blob hero__blob--warm"></span>
  </div>

  <div class="container hero__inner">
    <!-- TEXT -->
    <div class="hero__text">
      <span class="hero__eyebrow">
        <span class="hero__eyebrow-mark" aria-hidden="true">♪</span>
        {eyebrow}
      </span>
      <h1 class="hero__title">{title}</h1>
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
      <div class="hero__actions">
        <slot />
      </div>
      <div class="hero__social">
        <slot name="social" />
      </div>
    </div>

    <!-- VISUAL -->
    <div class="hero__visual">
      <!-- 後ろの淡いブロック（奥行き） -->
      <span class="hero__plate" aria-hidden="true"></span>

      <!-- 写真フレーム -->
      <div class="hero__frame">
        <img src={image} alt={imageAlt} loading="eager" decoding="async" />
      </div>

      <!-- Since 2002 バッジ -->
      <div class="hero__badge" aria-hidden="true">
        <span class="hero__badge-en">Since</span>
        <span class="hero__badge-year">2002</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* =============================================================
   * Layout
   * ============================================================= */
  .hero {
    position: relative;
    background: linear-gradient(180deg, #ffffff 0%, var(--color-bg-soft) 100%);
    padding-block: clamp(56px, 8vw, 96px);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .hero__blob {
    position: absolute;
    display: block;
    border-radius: 50%;
    filter: blur(70px);
  }
  .hero__blob--blue {
    width: 380px; height: 380px;
    background: rgba(19, 130, 185, 0.10);
    top: -120px; right: -80px;
  }
  .hero__blob--warm {
    width: 320px; height: 320px;
    background: rgba(251, 191, 36, 0.16);
    bottom: -100px; left: -80px;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  /* =============================================================
   * Text
   * ============================================================= */
  .hero__text {
    min-width: 0;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-accent);
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    background: var(--color-brand-50);
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    margin: 0 0 24px;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hero__eyebrow-mark {
    color: var(--color-warm-500);
    font-size: 1rem;
    line-height: 1;
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.7rem, 3.6vw, 2.6rem);
    line-height: 1.6;
    letter-spacing: 0.06em;
    margin: 0 0 22px;
    white-space: pre-line;
  }
  .hero__subtitle {
    color: var(--color-ink-2);
    font-size: clamp(0.95rem, 1.1vw, 1rem);
    line-height: 1.95;
    margin: 0 0 32px;
    max-width: 540px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .hero__social {
    margin-top: 28px;
    display: flex;
  }
  .hero__social:empty { display: none; }

  /* =============================================================
   * Visual (right column)
   *   - 親要素は relative & 固定の縦横比だけ持つ
   *   - フレーム・バッジ・後ろの板は absolute で重ねる
   * ============================================================= */
  .hero__visual {
    position: relative;
    width: 100%;
    max-width: 440px;
    aspect-ratio: 5 / 6;
    justify-self: end;
    margin: 8px 0;
  }

  /* 奥行きを出す淡い背景プレート */
  .hero__plate {
    position: absolute;
    inset: 14px -14px -14px 14px;
    background: var(--color-warm-100);
    border-radius: var(--radius-xl);
    z-index: 0;
  }

  /* 写真フレーム */
  .hero__frame {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-brand-50);
    box-shadow: 0 24px 56px rgba(19, 130, 185, 0.16);
    z-index: 1;
  }
  .hero__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Since 2002 バッジ */
  .hero__badge {
    position: absolute;
    left: -16px;
    bottom: -16px;
    width: 96px;
    height: 96px;
    background: #fff;
    border-radius: 50%;
    border: 4px solid var(--color-warm-200);
    box-shadow: 0 12px 28px rgba(19, 130, 185, 0.16);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    z-index: 2;
    transform: rotate(-6deg);
  }
  .hero__badge-en {
    font-family: var(--font-accent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--color-brand-600);
    text-transform: uppercase;
    line-height: 1;
  }
  .hero__badge-year {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1;
  }

  /* =============================================================
   * Responsive
   * ============================================================= */
  /* tablet & smaller -> 1 column */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }
    .hero__text { display: flex; flex-direction: column; align-items: center; }
    .hero__subtitle { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__social { justify-content: center; }
    .hero__visual {
      justify-self: center;
      max-width: 380px;
      aspect-ratio: 4 / 5;
    }
  }

  /* mobile */
  @media (max-width: 520px) {
    .hero__eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      padding: 5px 12px;
    }
    .hero__visual {
      max-width: 300px;
    }
    .hero__plate { inset: 10px -10px -10px 10px; }
    .hero__badge {
      width: 80px; height: 80px;
      left: -10px; bottom: -10px;
      border-width: 3px;
    }
    .hero__badge-year { font-size: 1.25rem; }
    .hero__badge-en { font-size: 0.68rem; }
    .hero__actions { width: 100%; }
    .hero__actions .btn { flex: 1 1 auto; }
  }
</style>
