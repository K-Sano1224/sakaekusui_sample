---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getConcerts, getConcertById } from '../../data/concerts';
import { formatDateJa } from '../../lib/format';
import type { Concert } from '../../types';

/**
 * 動的ルート: /concerts/[id]
 *
 * - getStaticPaths: ビルド時に全 ID の HTML を生成
 * - ページ本体: ID から microCMS を再取得（dev で追加された演奏会も表示可能）
 */
export const getStaticPaths = (async () => {
  const concerts = await getConcerts();
  return concerts.map((c) => ({
    params: { id: c.id },
  }));
}) satisfies GetStaticPaths;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/concerts');
}

const concert = await getConcertById(id);
if (!concert) {
  return Astro.redirect('/concerts');
}

const statusLabel: Record<Concert['status'], string> = {
  upcoming: '開催予定',
  soldout: '完売',
  finished: '終了',
};
const statusClass: Record<Concert['status'], string> = {
  upcoming: 'badge--brand',
  soldout: 'badge--peach',
  finished: 'badge--muted',
};

const d = new Date(concert.date);
const monthEn = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const month = Number.isNaN(d.getTime()) ? '' : monthEn[d.getMonth()];
const day = Number.isNaN(d.getTime()) ? '' : String(d.getDate()).padStart(2, '0');
const year = Number.isNaN(d.getTime()) ? '' : d.getFullYear();
---

<BaseLayout title={concert.title} description={concert.description}>
  <article class="cd">
    {/* HEAD */}
    <header class="cd__head">
      <div class="cd__head-deco cd__head-deco--1" aria-hidden="true"></div>
      <div class="cd__head-deco cd__head-deco--2" aria-hidden="true"></div>
      <div class="container container--narrow cd__head-inner">
        <a href="/concerts" class="cd__back" aria-label="演奏会一覧へ戻る">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          演奏会一覧へ戻る
        </a>

        <div class="cd__head-meta">
          <span class={`badge ${statusClass[concert.status]}`}>{statusLabel[concert.status]}</span>
          <time class="cd__head-date" datetime={concert.date}>
            {formatDateJa(concert.date, { withWeekday: true })}
          </time>
        </div>

        <h1 class="cd__title">{concert.title}</h1>

        <div class="cd__head-date-block" aria-hidden="true">
          <span class="cd__date-day">{day}</span>
          <span class="cd__date-mid">
            <span class="cd__date-month">{month}</span>
            <span class="cd__date-year">{year}</span>
          </span>
        </div>
      </div>
    </header>

    {/* MAIN */}
    <section class="section cd__section">
      <div class="container container--narrow">
        {/* メタ情報テーブル */}
        <dl class="cd__meta">
          {(concert.openTime || concert.startTime) && (
            <div class="cd__meta-row">
              <dt>時間</dt>
              <dd>
                {concert.openTime && <>開場 {concert.openTime}</>}
                {concert.openTime && concert.startTime && <span class="cd__sep"> / </span>}
                {concert.startTime && <>開演 {concert.startTime}</>}
              </dd>
            </div>
          )}
          <div class="cd__meta-row">
            <dt>会場</dt>
            <dd>
              {concert.venue}
              {concert.address && <span class="cd__muted">（{concert.address}）</span>}
            </dd>
          </div>
          <div class="cd__meta-row">
            <dt>料金</dt>
            <dd>{concert.fee}</dd>
          </div>
          {concert.conductor && (
            <div class="cd__meta-row">
              <dt>指揮</dt>
              <dd>{concert.conductor}</dd>
            </div>
          )}
          {concert.guest && (
            <div class="cd__meta-row">
              <dt>ゲスト</dt>
              <dd>{concert.guest}</dd>
            </div>
          )}
        </dl>

        {/* チラシ（content の上に表示） */}
        {concert.flyer && (
          <figure class="cd__flyer">
            <img
              src={concert.flyer.url}
              alt={concert.flyer.alt ?? `${concert.title}のチラシ`}
              width={concert.flyer.width}
              height={concert.flyer.height}
              loading="lazy"
              decoding="async"
            />
          </figure>
        )}

        {/* リッチエディタ本文（HTML 文字列）。microCMS の content 出力をそのまま受け取れる */}
        {concert.body && (
          <div class="cd__body prose" set:html={concert.body} />
        )}

        {/* プログラム（構造化版を優先） */}
        {concert.programSections && concert.programSections.length > 0 ? (
          <section class="cd__program">
            <h2 class="cd__program-title">プログラム</h2>
            <ol class="cd__program-list">
              {concert.programSections.map((sec) => (
                <li class="cd__program-section">
                  <h3 class="cd__program-section-title">{sec.title}</h3>
                  <ul>
                    {sec.items.map((item) => <li>{item}</li>)}
                  </ul>
                </li>
              ))}
            </ol>
          </section>
        ) : concert.program.length > 0 ? (
          <section class="cd__program">
            <h2 class="cd__program-title">主な演奏曲</h2>
            <ul class="cd__program-flat">
              {concert.program.map((item) => <li>{item}</li>)}
            </ul>
          </section>
        ) : null}

        {/* CTA */}
        {concert.ticketUrl && concert.status === 'upcoming' && (
          <p class="cd__cta">
            <a href={concert.ticketUrl} class="btn btn--primary" target="_blank" rel="noopener">
              チケット情報を見る
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M7 17L17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </p>
        )}

        {/* フッターナビ */}
        <nav class="cd__footnav" aria-label="ページ内ナビゲーション">
          <a href="/concerts" class="cd__footnav-link cd__footnav-link--prev">
            <span aria-hidden="true">←</span> すべての演奏会へ
          </a>
          <a href="/subscribe" class="cd__footnav-link">
            演奏会の案内通知を受け取る <span aria-hidden="true">→</span>
          </a>
        </nav>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* ============================================================
   * HEAD
   * ============================================================ */
  .cd__head {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #ffffff 0%, var(--color-bg-soft) 100%);
    border-bottom: 1px solid var(--color-line);
    padding-block: clamp(56px, 9vw, 96px) clamp(40px, 7vw, 72px);
  }
  .cd__head-deco {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    pointer-events: none;
  }
  .cd__head-deco--1 {
    width: 320px; height: 320px;
    background: rgba(19, 130, 185, 0.10);
    top: -100px; right: -60px;
  }
  .cd__head-deco--2 {
    width: 280px; height: 280px;
    background: rgba(251, 191, 36, 0.16);
    bottom: -120px; left: -60px;
  }
  .cd__head-inner {
    position: relative;
    z-index: 1;
  }

  .cd__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    color: var(--color-muted);
    margin-bottom: 28px;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--color-line);
    transition: color 0.2s var(--easing-out), border-color 0.2s var(--easing-out);
  }
  .cd__back:hover {
    color: var(--color-brand-700);
    border-color: var(--color-brand-200);
    text-decoration: none;
  }

  .cd__head-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 14px;
  }
  .cd__head-date {
    color: var(--color-muted);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }

  .cd__title {
    margin: 0 0 28px;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    letter-spacing: 0.06em;
    line-height: 1.55;
  }
  .cd__title::after {
    content: '';
    display: block;
    width: 48px;
    height: 4px;
    background: var(--color-warm-300);
    margin-top: 18px;
    border-radius: var(--radius-pill);
  }

  /* 日付プレート（飾り） */
  .cd__head-date-block {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    padding: 14px 22px;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xs);
    margin-top: 8px;
  }
  .cd__date-day {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .cd__date-mid {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .cd__date-month {
    font-family: var(--font-accent);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--color-brand-600);
  }
  .cd__date-year {
    font-family: var(--font-accent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }

  /* ============================================================
   * FLYER（content の上）
   * ============================================================ */
  .cd__flyer {
    margin: 0 0 40px;
    text-align: center;
  }
  .cd__flyer img {
    display: inline-block;
    max-width: min(100%, 360px);
    width: auto;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-line);
  }

  /* ============================================================
   * META TABLE
   * ============================================================ */
  .cd__meta {
    margin: 0 0 48px;
    padding: 28px 32px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    display: grid;
    gap: 4px;
  }
  .cd__meta-row {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 18px;
    padding: 12px 0;
    border-bottom: 1px dashed var(--color-line);
    font-size: 1rem;
    align-items: baseline;
  }
  .cd__meta-row:last-child { border-bottom: none; }
  .cd__meta dt {
    color: var(--color-muted);
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .cd__meta dd { margin: 0; color: var(--color-ink); }
  .cd__muted { color: var(--color-muted); font-size: 0.9rem; margin-left: 4px; }
  .cd__sep { color: var(--color-muted); }

  /* ============================================================
   * PROSE (リッチエディタ本文)
   *   microCMS リッチエディタの出力 HTML を素直に綺麗に描画する。
   * ============================================================ */
  .prose {
    color: var(--color-ink-2);
    font-size: 1rem;
    line-height: 1.95;
    margin-bottom: 48px;
  }
  .prose :where(p) { margin: 0 0 18px; }
  .prose :where(p:last-child) { margin-bottom: 0; }
  .prose :where(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.2rem, 1.6vw, 1.4rem);
    margin: 40px 0 16px;
    letter-spacing: 0.05em;
    padding-left: 14px;
    border-left: 4px solid var(--color-brand-500);
    line-height: 1.55;
  }
  .prose :where(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: 1.1rem;
    margin: 28px 0 12px;
    letter-spacing: 0.05em;
  }
  .prose :where(h4) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: 1rem;
    margin: 24px 0 8px;
  }
  .prose :where(ul, ol) {
    margin: 0 0 18px;
    padding-left: 1.6em;
  }
  .prose :where(li) { margin-bottom: 6px; }
  .prose :where(a) {
    color: var(--color-brand-700);
    border-bottom: 1.5px dotted var(--color-brand-200);
    padding-bottom: 1px;
    transition: border-color 0.2s var(--easing-out);
  }
  .prose :where(a:hover) {
    border-color: var(--color-brand-500);
    text-decoration: none;
  }
  .prose :where(strong) {
    color: var(--color-ink);
    font-weight: 700;
  }
  .prose :where(em) { font-style: italic; }
  .prose :where(blockquote) {
    margin: 24px 0;
    padding: 16px 22px;
    background: var(--color-bg-soft);
    border-left: 4px solid var(--color-brand-200);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-ink-2);
    font-size: 0.95rem;
  }
  .prose :where(blockquote p:last-child) { margin-bottom: 0; }
  .prose :where(hr) {
    border: none;
    border-top: 1px dashed var(--color-line);
    margin: 36px 0;
  }
  .prose :where(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 24px 0;
  }
  .prose :where(figure) {
    margin: 24px 0;
  }
  .prose :where(figcaption) {
    margin-top: 8px;
    color: var(--color-muted);
    font-size: 0.85rem;
    text-align: center;
  }
  .prose :where(code) {
    background: var(--color-bg-alt);
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 0.92em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .prose :where(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 0.95rem;
  }
  .prose :where(th, td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-line);
    text-align: left;
  }
  .prose :where(th) {
    background: var(--color-bg-alt);
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ============================================================
   * PROGRAM
   * ============================================================ */
  .cd__program {
    margin-bottom: 48px;
    padding: 32px 36px;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
  }
  .cd__program-title {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(1.2rem, 1.6vw, 1.4rem);
    margin: 0 0 20px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--color-warm-200);
    letter-spacing: 0.06em;
  }
  .cd__program-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .cd__program-section {
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    padding: 18px 22px;
  }
  .cd__program-section-title {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand-600);
    margin: 0 0 10px;
  }
  .cd__program-section ul,
  .cd__program-flat {
    margin: 0;
    padding-left: 1.4em;
    color: var(--color-ink);
    font-size: 0.98rem;
    line-height: 1.9;
  }
  .cd__program-section li,
  .cd__program-flat li { margin-bottom: 4px; }

  /* ============================================================
   * CTA & FOOTNAV
   * ============================================================ */
  .cd__cta {
    margin: 48px 0 36px;
    text-align: center;
  }
  .cd__cta .btn {
    min-width: 240px;
  }

  .cd__footnav {
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--color-line);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cd__footnav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.92rem;
    color: var(--color-brand-700);
    border-bottom: 1.5px dotted transparent;
    transition: gap 0.2s var(--easing-out), border-color 0.2s var(--easing-out);
  }
  .cd__footnav-link:hover {
    text-decoration: none;
    gap: 10px;
    border-color: var(--color-brand-300);
  }
  .cd__footnav-link--prev:hover { gap: 10px; }

  /* ============================================================
   * RESPONSIVE
   * ============================================================ */
  @media (max-width: 640px) {
    .cd__meta {
      padding: 22px 22px;
    }
    .cd__meta-row {
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 12px 0;
    }
    .cd__program {
      padding: 24px 22px;
    }
    .cd__head-date-block {
      padding: 12px 18px;
    }
    .cd__date-day { font-size: 1.8rem; }
  }
</style>
